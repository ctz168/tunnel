generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ServerConfig {
  id          String   @id @default(cuid())
  serverDomain String  @default("aicq.online:1018")
  updatedAt   DateTime @updatedAt
}

model Tunnel {
  id          String   @id @default(cuid())
  name        String
  tunnelCode  String   @unique
  localPort   Int
  localHost   String   @default("localhost")
  authToken   String   @unique
  protocol    String   @default("http")
  status      String   @default("offline")
  maxConn     Int      @default(10)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs TunnelLog[]
}

model TunnelLog {
  id        String   @id @default(cuid())
  tunnelId  String
  action    String
  message   String
  ip        String?
  bytesIn   Int      @default(0)
  bytesOut  Int      @default(0)
  createdAt DateTime @default(now())

  tunnel Tunnel @relation(fields: [tunnelId], references: [id], onDelete: Cascade)
}
