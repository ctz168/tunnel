{
  "name": "tunnel-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "DATABASE_URL=file:../../db/custom.db bun --hot index.ts",
    "start": "DATABASE_URL=file:../../db/custom.db bun index.ts",
    "postinstall": "cd .. && cd .. && DATABASE_URL=file:db/custom.db bunx prisma generate && cp -r node_modules/.prisma mini-services/tunnel-server/node_modules/.prisma 2>/dev/null || true"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "http-proxy": "^1.18.1",
    "@prisma/client": "^6.11.1"
  },
  "devDependencies": {
    "@types/ws": "^8.18.0",
    "@types/http-proxy": "^1.17.15",
    "bun-types": "^1.3.4"
  }
}
